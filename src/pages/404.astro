---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Signal lost" description="This log entry could not be located.">
  <section class="max-w-2xl mx-auto px-6 py-32 text-center" data-testid="not-found">
    <div class="mono text-[11px] tracking-widest text-terracotta-500 mb-4">// SIGNAL_LOST · 404</div>
    <h1 class="font-serif text-5xl sm:text-6xl font-semibold text-ink-900 leading-[1.05] tracking-tight mb-6"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;">
      Nothing here.
    </h1>
    <p class="text-lg text-ink-600 leading-relaxed mb-8">
      The log you're looking for was never written, or has been rotated out.
    </p>
    <a href="/" class="mono text-xs tracking-widest uppercase text-terracotta-500 hover:text-ink-900 transition-colors">
      ← Return to operational logs
    </a>
  </section>
</BaseLayout>
